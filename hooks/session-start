#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────
# DreamHive — SessionStart Hook
# Runs on every new Claude Code session:
#   1. Rebuild skill index (fast, ~100ms)
#   2. Inject bootstrap skill and status summary into context
# ─────────────────────────────────────────────────────────────
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
DREAMHIVE_PY="${PLUGIN_ROOT}/scripts/dreamhive.py"

# Rebuild skill index at session start
python3 "${DREAMHIVE_PY}" index >/dev/null 2>&1 || true

# Get compact status
STATUS_JSON=$(python3 "${DREAMHIVE_PY}" json-status 2>&1 || echo '{"total_skills":0,"total_invocations":0}')

TOTAL_SKILLS=$(echo "${STATUS_JSON}" | python3 -c "import sys,json; print(json.load(sys.stdin).get('total_skills',0))" 2>/dev/null || echo "0")
TOTAL_INVOCATIONS=$(echo "${STATUS_JSON}" | python3 -c "import sys,json; print(json.load(sys.stdin).get('total_invocations',0))" 2>/dev/null || echo "0")

RECENT_SKILLS=$(echo "${STATUS_JSON}" | python3 -c "
import sys, json
d = json.load(sys.stdin)
recent = d.get('recent_skills', [])
if recent:
    seen = []
    for s in recent:
        if s not in seen:
            seen.append(s)
    print(', '.join(seen[-5:]))
else:
    print('none')
" 2>/dev/null || echo "none")

# Read bootstrap skill content
BOOTSTRAP_CONTENT=$(cat "${PLUGIN_ROOT}/.claude/skills/dreamhive-bootstrap/SKILL.md" 2>&1 || echo "Failed to read bootstrap skill")

# Build context: bootstrap skill + status info
STATUS_LINE="🐝 DreamHive active: ${TOTAL_SKILLS} skills indexed, ${TOTAL_INVOCATIONS} invocations."
if [ "${RECENT_SKILLS}" != "none" ]; then
    STATUS_LINE="${STATUS_LINE} Recent: ${RECENT_SKILLS}."
fi
STATUS_LINE="${STATUS_LINE} Use /dreamhive-status for details, /dreamhive-suggest to find skills."

CONTEXT="<EXTREMELY_IMPORTANT>
You have DreamHive — an intelligent skill dispatch system.

${STATUS_LINE}

Below is your 'dreamhive:dreamhive-bootstrap' skill in full:

${BOOTSTRAP_CONTENT}
</EXTREMELY_IMPORTANT>"

# Use Python json.dumps to guarantee valid JSON output
CONTEXT_ESCAPED=$(printf '%s' "${CONTEXT}" | python3 -c "import sys,json; print(json.dumps(sys.stdin.read())[1:-1])")

# Output Claude Code hook format (multi-platform compatible)
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "${CONTEXT_ESCAPED}"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "${CONTEXT_ESCAPED}"
else
  printf '{\n  "additionalContext": "%s"\n}\n' "${CONTEXT_ESCAPED}"
fi

exit 0
